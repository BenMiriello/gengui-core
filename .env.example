# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (Postgres.app or Docker Postgres)
# Use port 5432 (standard Postgres port)
# Docker users: map with -p 5432:5432
DB_HOST=localhost
DB_PORT=5432
DB_USER=gengui
DB_PASSWORD=gengui_dev_pass
DB_NAME=gengui_media

# Redis (required)
# Used for: streams (job queues), Pub/Sub notifications, caching
# Recommended: Upstash (works for both Mac and remote inference-worker via Tailscale)
REDIS_URL=rediss://default:YOUR_TOKEN@your-redis-host.upstash.io:6379
# Alternative 1: Local Redis (only if running all services on same machine)
# REDIS_URL=redis://localhost:6379
# Alternative 2: Local Redis via Tailscale (expose to inference-worker)
# REDIS_URL=redis://100.x.x.x:6379

# FalkorDB (Graph Database)
# For deployed environments (Railway), use individual vars:
# FALKORDB_HOST=your-railway-host.proxy.rlwy.net
# FALKORDB_PORT=12345
# FALKORDB_PASSWORD=your-railway-password
# For local development with docker-compose:
FALKORDB_URL=redis://localhost:6381

# S3 Object Storage (AWS S3)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# Legacy MinIO config (deprecated, kept for code compatibility)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=media

# Inference Provider Configuration
# Text inference provider (for prompt augmentation, story analysis)
TEXT_INFERENCE_PROVIDER=gemini

# Image inference provider
# Options: gemini (default), runpod, local
IMAGE_INFERENCE_PROVIDER=gemini

# Gemini API (for text and image generation via Google AI)
# Required if TEXT_INFERENCE_PROVIDER=gemini OR IMAGE_INFERENCE_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key

# Entity Extraction Model (optional)
# Options: gemini-2.5-flash (default, fast/cheap), gemini-2.5-pro (slower/expensive but more accurate)
# Flash: $0.075/$0.30 per 1M tokens (input/output)
# Pro: $1.25/$10.00 per 1M tokens (17-33x more expensive)
# ENTITY_EXTRACTION_MODEL=gemini-2.5-pro

# OpenAI API (for embeddings - analysis version 0.0.1)
# Required for existing documents using OpenAI embeddings
OPENAI_API_KEY=your-openai-api-key

# Voyage AI API (for embeddings - analysis version 0.0.2+)
# Required for new documents using Voyage embeddings (current default)
# Get API key from https://dash.voyageai.com/
VOYAGE_API_KEY=your-voyage-api-key

# RunPod Serverless (for image generation)
# Required if IMAGE_INFERENCE_PROVIDER=runpod
# RUNPOD_API_KEY=RP-your-api-key
# RUNPOD_ENDPOINT_ID=your-endpoint-id

# GrowthBook (Feature Flags & A/B Testing)
# Generate secrets: openssl rand -hex 32
GROWTHBOOK_JWT_SECRET=your-jwt-secret-here
GROWTHBOOK_ENCRYPTION_KEY=your-encryption-key-here
GROWTHBOOK_API_HOST=http://localhost:3200
# SDK Client Key - get from GrowthBook UI after setup
GROWTHBOOK_CLIENT_KEY=

# Email Configuration (SMTP)
# TEMPORARY SOLUTION: Using Gmail for development/testing
# FUTURE: Migrate to Resend with custom domain (support@gengui.com)
#
# For development with Mailhog (local SMTP testing):
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM=GenGui Dev <dev@localhost>
#
# For production/testing with Gmail (TEMPORARY):
# 1. Enable 2FA on Google Account (https://myaccount.google.com/security)
# 2. Generate App Password (https://myaccount.google.com/apppasswords)
# 3. Use settings below:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=gengui247@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here
SMTP_FROM=GenGui <gengui247@gmail.com>

# Google OAuth Configuration (Optional)
# To enable Google Sign-In:
# 1. Create OAuth 2.0 Client at https://console.cloud.google.com/apis/credentials
# 2. Add authorized redirect URI: http://localhost:3000/api/auth/google/callback
# 3. Copy Client ID and Secret below
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Cookie Secret (for signed cookies)
# Generate with: openssl rand -hex 32
COOKIE_SECRET=dev-secret-change-in-production

# Google Drive Integration (Optional)
# Encryption key for storing Google OAuth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# GOOGLE_TOKEN_ENCRYPTION_KEY=your-64-char-hex-key-here

# Sentry (Error Tracking & Performance Monitoring)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# PostHog (Product Analytics)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Logging Configuration
LOG_LEVEL=debug  # debug | info | warn | error
LOG_VERBOSE=false  # true = log full prompts/responses/entity names (LOCAL ONLY, blocked in prod)
